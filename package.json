{
  "name": "wrdlnkdn",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "--- BOOT SEQUENCE (Environment Optimization) ---": "",
    "dev": "npm run build && node scripts/check-backend-env.mjs && concurrently -n \"API,VITE,SUPA,HEALTH\" -c \"magenta,blue,green,cyan\" \"npm run api\" \"npx wait-on http://127.0.0.1:3001/api/health -t 180000 && (sleep 3 || true) && npm run vite\" \"npm run supabase:start\" \"npm run health:launch\"",
    "health:launch": "bash ./scripts/health-check.sh",
    "launch": "npm run health:launch",
    "vite": "vite --config config/vite/vite.config.ts",
    "api": "tsx watch backend/server.ts",
    "--- SYSTEM AUDITS (Verification Layer) ---": "",
    "precheck": "bash ./scripts/precheck.sh",
    "check": "npm run typecheck && npm run lint && npm run lint:md && npm run format:check && npm run test:run",
    "check:full": "npm run check && npm run test:e2e:preview:chromium",
    "lint": "eslint -c config/eslint/eslint.config.cjs \"src/**/*.{js,jsx,ts,tsx}\" --cache --max-warnings=0 --format stylish && markdownlint \"**/*.md\"",
    "lint:fix": "eslint -c config/eslint/eslint.config.cjs \"src/**/*.{js,jsx,ts,tsx}\" --cache --fix && markdownlint \"**/*.md\" --fix",
    "lint:md": "markdownlint \"**/*.md\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix",
    "typecheck": "tsc -p config/typescript/tsconfig.app.json --noEmit --pretty false",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "--- TESTING (Behavioral Integrity) ---": "",
    "test": "vitest run -c config/vitest/vitest.config.ts",
    "test:watch": "vitest -c config/vitest/vitest.config.ts",
    "test:run": "vitest run -c config/vitest/vitest.config.ts",
    "test:unit": "vitest run -c config/vitest/vitest.unit.config.ts",
    "test:rls": "vitest run -c config/vitest/vitest.rls.config.ts",
    "test:e2e": "playwright test -c config/playwright/playwright.config.ts",
    "test:e2e:preview": "npm run build && cross-env PLAYWRIGHT_PREVIEW=true PLAYWRIGHT_FRONTEND_ONLY=true playwright test -c config/playwright/playwright.config.ts",
    "test:e2e:preview:chromium": "npm run build && cross-env PLAYWRIGHT_PREVIEW=true PLAYWRIGHT_FRONTEND_ONLY=true playwright test -c config/playwright/playwright.config.ts --project=chromium",
    "test:e2e:preview:a11y": "npm run build && cross-env PLAYWRIGHT_PREVIEW=true PLAYWRIGHT_FRONTEND_ONLY=true playwright test -c config/playwright/playwright.config.ts src/tests/e2e/accessibility.spec.ts",
    "test:e2e:a11y": "playwright test -c config/playwright/playwright.config.ts src/tests/e2e/accessibility.spec.ts",
    "test:e2e:ui": "playwright test -c config/playwright/playwright.config.ts --ui",
    "playwright:install": "playwright install --with-deps chromium chromium-headless-shell",
    "playwright:install:all": "playwright install --with-deps chromium chromium-headless-shell firefox",
    "lighthouse:prod": "npx --yes lighthouse https://wrdlnkdn.vercel.app/ --only-categories=performance,accessibility,best-practices,seo --preset=desktop --quiet --chrome-flags=\"--headless\"",
    "lighthouse:prod:mobile": "npx --yes lighthouse https://wrdlnkdn.vercel.app/ --only-categories=performance,accessibility,best-practices,seo --form-factor=mobile --screenEmulation.mobile=true --quiet --chrome-flags=\"--headless\"",
    "e2e:serve": "concurrently -k -n VITE,API \"vite --config config/vite/vite.config.ts --host 127.0.0.1 --port 5173 --strictPort\" \"tsx backend/server.ts\"",
    "e2e:serve:ci": "vite --config config/vite/vite.config.ts --host 127.0.0.1 --port 5173 --strictPort",
    "e2e:serve:frontend": "vite --config config/vite/vite.config.ts --host 127.0.0.1 --port 5173 --strictPort",
    "e2e:serve:backend": "tsx backend/server.ts",
    "--- DATABASE (Physical Layer) ---": "",
    "supabase:start": "npx supabase@latest start",
    "supabase:stop": "npx supabase@latest stop",
    "supabase:reset": "bash ./scripts/supabase-reset.sh",
    "supabase:push-uat": "npx supabase@latest link --project-ref lgxwseyzoefxggxijatp && npx supabase@latest db push --linked --include-all --include-seed -p \"${SUPABASE_DB_PASSWORD}\"",
    "supabase:push-prod": "npx supabase@latest link --project-ref rpcaazmxymymqdejevtb && npx supabase@latest db push --linked --include-all --include-seed -p \"${SUPABASE_DB_PASSWORD}\"",
    "supabase:gen-types": "npx supabase@latest gen types typescript --local | node scripts/gen-supabase-types.mjs",
    "--- BUILD & DEPLOY (Legacy Code Prevention) ---": "",
    "build": "tsc -b config/typescript/tsconfig.app.json config/typescript/tsconfig.node.json && vite build --config config/vite/vite.config.ts",
    "preview": "vite preview --config config/vite/vite.config.ts",
    "prepare": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || husky",
    "deps:latest": "npx npm-check-updates -u && npm install",
    "deps:audit:fix": "npm audit fix",
    "deps:audit:fix:force": "npm audit fix --force"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint --fix"
    ],
    "*.{json,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.10",
    "@mui/material": "7.3.10",
    "@supabase/supabase-js": "2.103.0",
    "cors": "2.8.6",
    "emoji-picker-react": "4.18.0",
    "express": "5.2.1",
    "leo-profanity": "1.9.0",
    "mammoth": "1.12.0",
    "multer": "2.1.1",
    "pdf-lib": "1.17.1",
    "pdfkit": "0.18.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-helmet-async": "3.0.0",
    "react-router-dom": "7.14.0",
    "secure-json-parse": "4.1.0",
    "sharp": "0.34.5",
    "uuid": "13.0.0",
    "word-extractor": "1.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "@types/pdfkit": "0.17.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "dotenv": "17.4.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.2",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.7",
    "vitest": "4.1.4",
    "wait-on": "9.0.5"
  },
  "overrides": {
    "minimatch": "^10.2.4"
  }
}
